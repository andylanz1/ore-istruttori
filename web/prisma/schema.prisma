generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  nome          String
  cognome       String
  email         String?
  telefono      String    @unique
  passwordHash  String?
  ruolo                String    @default("istruttore") // "admin" | "responsabile" | "istruttore"
  attivo               Boolean   @default(true)
  compensoFissoMensile Float?    // €/mese fisso (alternativo a tariffe per lezione)
  dbgymNickname        String?   // nickname in DBGym PrenotazioniLezioni.Note (es. "stefania", "raky")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  registrazioniOre RegistrazioneOre[]
  tariffe          TariffaIstruttore[]
  compensiMensili  CompensoMensile[]
  sessions         Session[]
  accounts         Account[]

  @@map("users")
}

model RegistrazioneOre {
  id            String   @id @default(cuid())
  userId        String?  // nullable per lezioni TURNI (rotazione)
  data          DateTime // giorno specifico
  oraInizio     String   // "09:00" — ora inizio lezione
  attivita      String   // es. "Pilates", "In-Trinity", "WBS"
  partecipanti  Int?     // popolato automaticamente da DBGym
  compenso      Float?   // € calcolato in base a tariffa + partecipanti
  note          String?
  stato         String   @default("bozza") // "bozza" | "da_confermare" | "confermato" | "rifiutato"
  sorgente      String   @default("manuale") // "manuale" | "dbgym"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, data, oraInizio])
  @@map("registrazioni_ore")
}

// Compenso personalizzato per istruttore + attività
model TariffaIstruttore {
  id            String   @id @default(cuid())
  userId        String
  attivita      String   // es. "Pilates", "PT 1h"
  compenso      Float    // €/lezione (o fascia bassa 1-4 partecipanti)
  compensoAlto  Float?   // €/lezione fascia alta (5+ partecipanti), null = tariffa fissa
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, attivita])
  @@map("tariffe_istruttore")
}

// Storico compensi mensili (per mesi chiusi, es. gen/feb importati manualmente)
model CompensoMensile {
  id        String   @id @default(cuid())
  userId    String
  mese      Int      // 1-12
  anno      Int      // es. 2026
  importo   Float    // € totale del mese
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mese, anno])
  @@map("compensi_mensili")
}

// NextAuth.js models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

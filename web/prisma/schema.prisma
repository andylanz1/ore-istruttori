generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  nome          String
  cognome       String
  email         String    @unique
  telefono      String?
  passwordHash  String
  ruolo         String    @default("istruttore") // "admin" | "responsabile" | "istruttore"
  attivo        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  registrazioniOre RegistrazioneOre[]
  tariffe          TariffaIstruttore[]
  sessions         Session[]
  accounts         Account[]

  @@map("users")
}

model RegistrazioneOre {
  id            String   @id @default(cuid())
  userId        String
  data          DateTime // giorno specifico
  oraInizio     String   // "09:00" — ora inizio lezione
  attivita      String   // es. "Pilates", "In-Trinity", "WBS"
  partecipanti  Int?     // popolato automaticamente da DBGym
  compenso      Float?   // € calcolato in base a tariffa + partecipanti
  note          String?
  stato         String   @default("bozza") // "bozza" | "confermato"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, data, oraInizio])
  @@map("registrazioni_ore")
}

// Compenso personalizzato per istruttore + attività
model TariffaIstruttore {
  id            String   @id @default(cuid())
  userId        String
  attivita      String   // es. "Pilates", "PT 1h"
  compenso      Float    // €/lezione (o fascia bassa 1-4 partecipanti)
  compensoAlto  Float?   // €/lezione fascia alta (5+ partecipanti), null = tariffa fissa
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, attivita])
  @@map("tariffe_istruttore")
}

// NextAuth.js models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

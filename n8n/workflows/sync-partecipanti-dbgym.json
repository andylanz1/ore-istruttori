      "id": "trigger-1",
      "name": "Trigger 03:00",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [220, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n    pl.Descrizione AS corso_dbgym,\n    CONVERT(VARCHAR(5), pi.DataInizio, 108) AS ora,\n    CONVERT(VARCHAR(10), CAST(pi.DataInizio AS DATE), 23) AS data,\n    COUNT(DISTINCT pi.IDUtente) AS partecipanti\nFROM dbgym.dbo.PrenotazioniIscrizione pi\nINNER JOIN dbgym.dbo.PrenotazioniLezioni pll\n    ON pi.IDPrenotazioneLezione = pll.IDPrenotazioneLezione\nINNER JOIN dbgym.dbo.Prenotazioni pl\n    ON pi.IDPrenotazione = pl.IDPrenotazione\nWHERE CAST(pi.DataInizio AS DATE) = CAST(DATEADD(day, -1, GETDATE()) AS DATE)\n  AND pi.IDUtente IS NOT NULL\n  AND pi.IDPrenotazione <> 172\n  AND pl.Attivo <> 0\nGROUP BY pl.Descrizione, CONVERT(VARCHAR(5), pi.DataInizio, 108), CAST(pi.DataInizio AS DATE)",
        "options": {}
      },
      "id": "sql-presenze",
      "name": "SQL - Presenze Ieri",
      "type": "n8n-nodes-base.microsoftSql",
      "typeVersion": 1,
      "position": [440, 300],
      "credentials": {
        "microsoftSql": {
          "id": "YHZnCr0OGdg1ygM8",
          "name": "DBGym SQL Server"
        }
      },
      "continueOnFail": true
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const MAPPING = {\n  'STUDIO 1 REFORMER': 'Pilates',\n  'STUDIO 2 REFORMER': 'Pilates',\n  'IN-TRINITY': 'In-Trinity',\n  'WBS POSTURALE': 'WBS',\n  'PILOGA': 'Piloga',\n  'SHAPE & TONE': 'Functional',\n  'EASY STUDIO 1': 'Easy Reformer',\n  'EASY STUDIO 2': 'Easy Reformer',\n  'WBS EASY POSTURALE': 'Easy WBS',\n  'ESTATE REFORMER': 'Pilates',\n  'ESTATE WBS': 'WBS',\n};\n\nconst rows = $input.all();\n\n// Check for SQL error\nif (rows.length > 0 && rows[0].json.error) {\n  return [{ json: { skip: false, error: true, errorMsg: rows[0].json.error.message || 'Errore SQL' } }];\n}\n\nif (rows.length === 0) {\n  return [{ json: { skip: true } }];\n}\n\nconst data = rows[0].json.data;\nconst items = rows.map(r => {\n  const att = MAPPING[r.json.corso_dbgym];\n  if (!att) return null;\n  return {\n    attivita: att,\n    oraInizio: r.json.ora,\n    partecipanti: r.json.partecipanti\n  };\n}).filter(Boolean);\n\nif (items.length === 0) {\n  return [{ json: { skip: true } }];\n}\n\nreturn [{ json: { data, items, skip: false, error: false } }];"
      },
      "id": "code-mapping",
      "name": "Mapping Nomi",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 300]
    },

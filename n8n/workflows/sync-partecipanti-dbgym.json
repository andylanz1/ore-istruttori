    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const mappingData = $('Mapping Nomi').first().json;\n\n// SQL error\nif (mappingData.error) {\n  return [{ json: { hasError: true, text: `ERRORE Sync Partecipanti\\nSQL: ${mappingData.errorMsg}` } }];\n}\n\n// HTTP error\nconst result = $input.first().json;\nif (result.error || result.statusCode >= 400) {\n  const msg = result.error?.message || result.message || JSON.stringify(result).slice(0, 200);\n  return [{ json: { hasError: true, text: `ERRORE Sync Partecipanti\\nAPI: ${msg}` } }];\n}\n\n// Success — silent\nreturn [{ json: { hasError: false } }];"
      },

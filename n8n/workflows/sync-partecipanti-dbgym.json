{
  "id": "sync-partecipanti-dbgym",
  "name": "Sync Partecipanti DBGym -> ore-istruttori",
  "active": false,
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 3 * * *"
